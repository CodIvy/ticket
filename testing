import http from 'k6/http';
import { check } from 'k6';

export const options = {
    scenarios: {
        race_condition_test: {
            executor: 'per-vu-iterations',
            vus: 100,                      // 100 користувачів
            iterations: 1,                 // 1 запит
            maxDuration: '15s',
        },
    },
};

export default function () {
    // Публічна адреса в Azure
    const url = 'http://172.201.98.124:8000/concert/book';

    // Тестуємо місце під ID
    const payload = {
        seat_id: '10',
    };

    const params = {
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            // !! Передаємо користувача яки існує
            'Cookie': 'user_id=1',
        },
        // Прибираємо редіректи
        redirects: 0,
    };

    const res = http.post(url, payload, params);

    // 303 повинен повернути лише 1 запит
    check(res, {
        'Статус 303 або 409': (r) => r.status === 303 || r.status === 409,
    });
}